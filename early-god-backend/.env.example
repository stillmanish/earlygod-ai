# ============================================================
# EarlyGod.ai — Backend Environment Variables
# ============================================================
# Copy this file to .env and fill in your own values.
# DO NOT commit .env to git (it's in .gitignore).
#
# Required keys to run: OPENAI_API_KEY (or GEMINI_API_KEY),
# DEEPGRAM_API_KEY, ELEVENLABS_API_KEY, plus a database URL.
# ============================================================

# ----- Server Configuration -----
PORT=3001
NODE_ENV=development

# ----- AI Provider (REQUIRED — pick at least one) -----

# OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_ORGANIZATION=
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview

# Google Gemini (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Tuned Gemini model ID (optional, for fine-tuned models)
TUNED_GEMINI_MODEL_ID=

# ----- Voice Services (REQUIRED for voice features) -----

# Deepgram for transcription (https://console.deepgram.com/)
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# ElevenLabs for text-to-speech (https://elevenlabs.io/app/settings/api-keys)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_AGENT_ID=

# ----- Database (REQUIRED) -----

# Postgres connection string (recommend Neon — https://neon.tech for free tier)
DATABASE_URL=postgresql://user:password@host/database?sslmode=require
NEON_DATABASE_API=postgresql://user:password@host/database?sslmode=require

# ----- Authentication (Optional — Clerk) -----
# Sign up at https://clerk.com if you want auth
# To use a different auth provider (Auth0, Supabase, Firebase, custom JWT), see docs/AUTH.md
# Leave empty to run in no-auth mode (single-user local app, no login required)
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_FRONTEND_API=

# ----- Optional integrations -----

# YouTube Data API (for fetching game guide videos)
# https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=
