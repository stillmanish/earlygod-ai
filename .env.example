# ============================================================
# earlygod.ai — Environment Variables (single root config)
# ============================================================
# Copy this file to .env and fill in your values.
# Both backends read from this file at the repo root.
# DO NOT commit .env to git (it's in .gitignore).
#
# Quick start: run `npm run setup` to fill this in interactively.
# ============================================================

# ----- AI Provider (REQUIRED — pick at least one) -----
# OpenAI:   https://platform.openai.com/api-keys
# Gemini:   https://aistudio.google.com/apikey
# Claude:   https://console.anthropic.com
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# ----- Voice Services (REQUIRED for voice features) -----
# Deepgram (STT):    https://console.deepgram.com/   (free $200 credit)
# ElevenLabs (TTS):  https://elevenlabs.io/app/settings/api-keys
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=

# ----- Database (OPTIONAL) -----
# If left empty, the app falls back to a local SQLite database.
# For Postgres, sign up free at https://neon.tech
DATABASE_URL=

# ----- Authentication (OPTIONAL) -----
# Leave empty for no-auth single-user mode.
# Sign up at https://clerk.com if you want auth.
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_FRONTEND_API=

# ----- Optional integrations -----
YOUTUBE_API_KEY=

# ----- Server config -----
PORT=3001
QUEST_MODE_PORT=8081
NODE_ENV=development
