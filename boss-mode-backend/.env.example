# ============================================================
# EarlyGod.ai — Quest Mode Backend Environment Variables
# ============================================================
# This is the secondary backend for proactive vision analysis
# (formerly called "boss-mode-backend").
#
# Runs on a separate port to avoid blocking the main backend's
# real-time audio streaming.
# ============================================================

# Port for this service
PORT=8081

# Gemini API key (required — used for vision analysis)
# Get one at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# URL of the main backend (early-god-backend)
# Used for cross-service communication
MAIN_BACKEND_URL=http://localhost:3001
